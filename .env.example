# GitHub AI Trend Tracker - Environment Variables
# Copy this file to .env and fill in your actual values

# =============================================================================
# REQUIRED - GitHub API Token
# =============================================================================
# Get from: https://github.com/settings/tokens
# Required scopes: public_repo (only this one!)
# This fetches repository data from GitHub API
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# =============================================================================
# OPTIONAL - MotherDuck (Cloud Database)
# =============================================================================
# Only needed if you want to use cloud database instead of local DuckDB
# Get from: https://app.motherduck.com/ → Account Settings
# MotherDuck stores your data in the cloud for dashboard hosting
MOTHERDUCK_TOKEN=eyJxxxxxxxx.xxxxxxxx.xxxxxxxx

# =============================================================================
# OPTIONAL - Development Settings
# =============================================================================
# Uncomment if you want to change defaults
# DBT_PROFILES_DIR=./dbt
